.interview-content {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.difficulty-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.option-card {
  min-height: 132rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 2rpx solid transparent;
  box-shadow: var(--shadow);
}

.option-card.active {
  border-color: #2764e8;
  background: #edf4ff;
}

.option-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.option-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-secondary);
}

.difficulty-card {
  min-height: 142rpx;
  text-align: center;
}

.range-panel {
  margin-top: 30rpx;
}

.range-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.range-row.second {
  margin-top: 30rpx;
}

.range-title {
  font-size: 28rpx;
  font-weight: 800;
}

.range-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
}

.range-value {
  min-width: 126rpx;
  text-align: right;
  color: #2764e8;
  font-size: 30rpx;
  font-weight: 900;
}
