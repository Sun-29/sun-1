.sub-content {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.upload-card {
  padding: 34rpx;
  text-align: center;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: var(--shadow);
}

.upload-icon,
.file-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #2764e8;
  background: #edf4ff;
  font-weight: 900;
}

.upload-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 22rpx;
  border-radius: 32rpx;
  font-size: 34rpx;
}

.upload-title {
  font-size: 34rpx;
  font-weight: 900;
}

.upload-desc {
  margin: 12rpx 0 28rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.file-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  height: 104rpx;
  padding: 18rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(246, 248, 252, 0.96);
  backdrop-filter: blur(12rpx);
}

.back-btn {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #fff;
  color: var(--text-primary);
  font-size: 34rpx;
  box-shadow: var(--shadow);
}

.detail-title {
  font-size: 32rpx;
  font-weight: 900;
}

.detail-content {
  padding-top: 0;
}

.score-hero {
  padding: 38rpx;
  text-align: center;
  color: #fff;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 86% 0%, rgba(18, 184, 134, 0.34), transparent 34%),
    linear-gradient(135deg, #2764e8, #169bd7);
  box-shadow: 0 22rpx 52rpx rgba(39, 100, 232, 0.24);
  margin-bottom: 22rpx;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

.score-number {
  margin-top: 8rpx;
  font-size: 86rpx;
  line-height: 1;
  font-weight: 900;
}

.score-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.resume-score-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.resume-score-row.last {
  border-bottom: 0;
}

.resume-score-title {
  font-size: 27rpx;
  font-weight: 800;
}

.resume-score-desc {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 23rpx;
  line-height: 1.5;
}

.score-pill {
  flex-shrink: 0;
  min-width: 84rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 900;
}

.bullet-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.65;
}

.bullet-row:last-child {
  border-bottom: 0;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.paragraph {
  margin-top: 16rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.75;
}

.plan-row {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fbff;
}

.plan-title {
  font-size: 27rpx;
  font-weight: 900;
}

.plan-result {
  margin-top: 8rpx;
  color: #087f5b;
  font-size: 24rpx;
  line-height: 1.6;
}
