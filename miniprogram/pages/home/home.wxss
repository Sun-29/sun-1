.home-hero {
  padding-top: 42rpx;
}

.home-user {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.home-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.38);
}

.home-metrics {
  margin-top: 36rpx;
}

.home-content {
  margin-top: -44rpx;
  position: relative;
  z-index: 2;
}

.start-card {
  min-height: 172rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #fff;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 84% 0%, rgba(255, 255, 255, 0.25), transparent 28%),
    linear-gradient(135deg, #172033 0%, #2764e8 100%);
  box-shadow: 0 22rpx 52rpx rgba(39, 100, 232, 0.24);
}

.start-copy {
  flex: 1;
  min-width: 0;
}

.start-title {
  font-size: 34rpx;
  font-weight: 900;
}

.start-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.5;
}

.start-btn {
  width: 150rpx;
  min-height: 74rpx;
  background: #fff;
  color: #2764e8;
  box-shadow: none;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-card {
  min-height: 192rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #fff;
  border: 1rpx solid rgba(232, 237, 245, 0.92);
  box-shadow: var(--shadow);
}

.quick-icon {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.quick-title {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.quick-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: var(--text-secondary);
}

.interview-card {
  padding: 24rpx;
}

.record-icon {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 20rpx;
  color: #2764e8;
  background: #edf4ff;
  font-size: 26rpx;
  font-weight: 900;
}

.record-score {
  min-width: 116rpx;
  text-align: right;
  font-size: 34rpx;
  font-weight: 900;
}

.record-score .tag {
  margin-top: 8rpx;
  margin-right: 0;
  min-height: 40rpx;
  padding: 0 14rpx;
  font-size: 20rpx;
}
