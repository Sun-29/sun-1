.question-content {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 62rpx;
  margin-right: 12rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  background: #fff;
  border: 1rpx solid var(--border);
  font-size: 25rpx;
  font-weight: 700;
}

.category-pill.active {
  color: #fff;
  background: #2764e8;
  border-color: #2764e8;
  box-shadow: 0 12rpx 24rpx rgba(39, 100, 232, 0.22);
}

.question-card {
  padding: 24rpx;
}

.question-index {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 18rpx;
  color: #2764e8;
  background: #edf4ff;
  font-size: 25rpx;
  font-weight: 900;
}

.question-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.favorite-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #8a96a8;
  background: #eef2f7;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.favorite-btn.active {
  color: #a16300;
  background: #fff7e6;
}
