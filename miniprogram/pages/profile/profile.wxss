.profile-hero {
  text-align: center;
  padding-bottom: 84rpx;
}

.profile-avatar {
  width: 144rpx;
  height: 144rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.42);
}

.profile-name {
  margin-top: 20rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.profile-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.profile-content {
  margin-top: -54rpx;
  position: relative;
  z-index: 2;
}

.profile-metrics {
  margin-bottom: 24rpx;
}

.score-blue {
  color: #2764e8;
}

.score-green {
  color: #12b886;
}

.score-orange {
  color: #f59f00;
}

.menu-card {
  padding: 8rpx 24rpx;
}

.menu-row {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--border);
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.menu-icon {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #edf4ff;
  color: #2764e8;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
}

.logout-btn {
  margin-top: 30rpx;
  color: #ef4444;
  background: #fff1f2;
  border-color: rgba(239, 68, 68, 0.18);
}
