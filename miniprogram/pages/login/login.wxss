.login-page {
  min-height: 100vh;
  padding: 82rpx 32rpx calc(42rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 86% 10%, rgba(18, 184, 134, 0.36), transparent 28%),
    linear-gradient(180deg, #2764e8 0%, #1a82c8 42%, #f6f8fc 42%, #f6f8fc 100%);
}

.login-hero {
  color: #fff;
}

.brand-mark {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  font-size: 38rpx;
  font-weight: 900;
}

.login-title {
  margin-top: 34rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.15;
}

.login-subtitle {
  margin-top: 12rpx;
  font-size: 27rpx;
  color: rgba(255, 255, 255, 0.82);
}

.login-panel {
  margin-top: 58rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 24rpx 60rpx rgba(30, 45, 78, 0.12);
}

.mode-tabs {
  height: 76rpx;
  padding: 8rpx;
  display: flex;
  gap: 8rpx;
  border-radius: 24rpx;
  background: #f1f5fb;
  margin-bottom: 30rpx;
}

.mode-tab {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #687385;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tab.active {
  color: #2764e8;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(30, 45, 78, 0.08);
}

.field-group {
  margin-bottom: 24rpx;
}

.switch-line {
  margin-top: 24rpx;
  text-align: center;
  color: #8a96a8;
  font-size: 25rpx;
}

.switch-link {
  margin-left: 8rpx;
  color: #2764e8;
  font-weight: 700;
}

.divider {
  position: relative;
  margin: 34rpx 0 24rpx;
  text-align: center;
  color: #a4adba;
  font-size: 23rpx;
}

.divider::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1rpx;
  background: #edf1f7;
}

.divider text {
  position: relative;
  padding: 0 22rpx;
  background: #fff;
}

.wechat-btn {
  color: #087f5b;
  background: #e7fbf4;
  border-color: rgba(18, 184, 134, 0.24);
}
