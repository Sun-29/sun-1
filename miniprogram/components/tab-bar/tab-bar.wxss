.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  min-height: 108rpx;
  padding: 10rpx;
  z-index: 999;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(232, 237, 245, 0.94);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 52rpx rgba(25, 40, 72, 0.16);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8a96a8;
  border-radius: 26rpx;
}

.tab-item.active {
  color: #2764e8;
  background: #edf4ff;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #eef2f7;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 8rpx;
}

.tab-item.active .tab-icon {
  color: #fff;
  background: #2764e8;
}

.tab-label {
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}
